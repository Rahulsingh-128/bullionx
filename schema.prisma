// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MetalPrice {
  id             String   @id @default(cuid())
  metal          Metal
  pricePerGramINR Float
  pricePerOzUSD  Float
  usdInrRate     Float
  percentChange  Float
  source         String
  createdAt      DateTime @default(now())

  @@index([metal, createdAt])
}

enum Metal {
  GOLD
  SILVER
}
